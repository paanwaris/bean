Package: bean
Type: Package
Title: Data Thinning of Species Occurrences in Environmental Space
Version: 0.2.1
Authors@R: c(
    person("Paanwaris", "Paansri",
           role = c("cre", "aut"),
           email = "paanwaris@vt.edu",
